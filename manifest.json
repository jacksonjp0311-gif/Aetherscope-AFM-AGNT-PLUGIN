{
  "name": "aetherscop-afm",
  "displayName": "AetherScope AFM",
  "version": "1.1.0",
  "description": "AFM-derived volumetric field processing and Omega-basin analysis toolkit. Zero-dependency, offline, local-first.",
  "author": "James Paul Jackson",
  "icon": "wave",
  "homepage": "https://github.com/jacksonjp0311-gif/Aetherscope-AFM-AGNT-PLUGIN",
  "category": "science",
  "tags": [
    "afm",
    "science",
    "analysis",
    "volumetric",
    "harmonic-fields"
  ],
  "python": {
    "packageDir": "src",
    "module": "aetherscope_afm",
    "installCommand": "pip install -e .",
    "depsFile": "pyproject.toml"
  },
  "tools": [
    {
      "type": "aetherscop-afm-preprocess",
      "entryPoint": "./index.js",
      "schema": {
        "title": "Preprocess",
        "description": "Clip, normalize, superresolve AFM volumes",
        "parameters": {
          "input_path": {
            "type": "string",
            "required": true
          },
          "clip_min": {
            "type": "number"
          },
          "clip_max": {
            "type": "number"
          },
          "superres": {
            "type": "number",
            "default": 1
          },
          "max_size": {
            "type": "number",
            "default": 128
          }
        }
      }
    },
    {
      "type": "aetherscop-afm-harmonic-field",
      "entryPoint": "./index.js",
      "schema": {
        "title": "Harmonic Field",
        "description": "Build T-frame sinusoidal harmonic field tensor",
        "parameters": {
          "volume_path": {
            "type": "string",
            "required": true
          },
          "T": {
            "type": "number",
            "default": 8
          }
        }
      }
    },
    {
      "type": "aetherscop-afm-metrics",
      "entryPoint": "./index.js",
      "schema": {
        "title": "Metrics",
        "description": "Triad E/I/C, lambda_eff, curvature, omega correlation",
        "parameters": {
          "volume": {
            "type": "string",
            "required": true
          },
          "delta_phi": {
            "type": "string"
          },
          "omega_base": {
            "type": "string"
          },
          "omega_noisy": {
            "type": "string"
          }
        }
      }
    },
    {
      "type": "aetherscop-afm-dashboard",
      "entryPoint": "./index.js",
      "schema": {
        "title": "Dashboard",
        "description": "Full pipeline: visuals + metrics + ledger",
        "parameters": {
          "input_path": {
            "type": "string",
            "required": true
          },
          "output_root": {
            "type": "string",
            "default": "outputs"
          },
          "config_path": {
            "type": "string"
          },
          "profile": {
            "type": "string",
            "default": "demo"
          }
        }
      }
    },
    {
      "type": "aetherscop-afm-run-single",
      "entryPoint": "./index.js",
      "schema": {
        "title": "Run Single",
        "description": "End-to-end single volume analysis",
        "parameters": {
          "input_path": {
            "type": "string",
            "required": true
          },
          "config": {
            "type": "string"
          },
          "profile": {
            "type": "string",
            "default": "default"
          },
          "output_root": {
            "type": "string"
          }
        }
      }
    },
    {
      "type": "open-url",
      "entryPoint": "./open_url_tool.js",
      "schema": {
        "title": "Open URL",
        "description": "Open a URL in the system browser",
        "parameters": {
          "url": {
            "type": "string",
            "required": true
          },
          "new": {
            "type": "number",
            "default": 1
          }
        }
      }
    },
    {
      "type": "aetherscop-afm-telemetry",
      "entryPoint": "./index.js",
      "schema": {
        "title": "Telemetry",
        "description": "Emit Codex-ready JSON telemetry",
        "parameters": {
          "metrics_json": {
            "type": "string",
            "required": true
          },
          "output_path": {
            "type": "string"
          }
        }
      }
    },
    {
      "type": "aetherscop-afm-ledger",
      "entryPoint": "./index.js",
      "schema": {
        "title": "Ledger",
        "description": "Append governance ledger entry with gratitude hash",
        "parameters": {
          "output_root": {
            "type": "string",
            "required": true
          },
          "sample_id": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "metrics": {
            "type": "string"
          }
        }
      }
    },
    {
      "type": "aetherscop-afm-visualize",
      "entryPoint": "./index.js",
      "schema": {
        "title": "Visualize",
        "description": "Generate PNG dashboard visualizations",
        "parameters": {
          "volume_slice": {
            "type": "string"
          },
          "field_slice": {
            "type": "string"
          },
          "omega_slice": {
            "type": "string"
          },
          "output_dir": {
            "type": "string",
            "required": true
          }
        }
      }
    },
    {
      "type": "aetherscop-afm-file-explorer",
      "entryPoint": "./file_tools.js",
      "schema": {
        "title": "File Explorer",
        "description": "Browse directories and list .npy volumes",
        "parameters": {
          "base_path": {
            "type": "string",
            "default": "."
          }
        }
      }
    },
    {
      "type": "aetherscop-afm-file-search",
      "entryPoint": "./file_tools.js",
      "schema": {
        "title": "File Search",
        "description": "Grep/regex search across volume collections",
        "parameters": {
          "base_path": {
            "type": "string",
            "required": true
          },
          "pattern": {
            "type": "string",
            "required": true
          }
        }
      }
    },
    {
      "type": "aetherscop-afm-file-analyze",
      "entryPoint": "./file_tools.js",
      "schema": {
        "title": "File Analyze",
        "description": "Quick metadata + shape + dtype summary",
        "parameters": {
          "input_path": {
            "type": "string",
            "required": true
          }
        }
      }
    }
  ],
  "integrations": [
    {
      "service": "open-url-toolkit",
      "capability": "preview",
      "description": "Preview dashboard PNGs in AGNT"
    }
  ]
}
